# SAT Tutor Pro — Environment Variables
# Copy this file to .env.local and fill in your values

# Anthropic API (required)
# Get your key at: https://console.anthropic.com/api-keys
ANTHROPIC_API_KEY=sk-ant-...

# Supabase (required)
# Get these from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# App Config
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Student Config (dev only — not used when Supabase Auth is enabled)
# NEXT_PUBLIC_DEFAULT_STUDENT_ID=jason_001
# NEXT_PUBLIC_STUDENT_NAME=Jason

# Resend — email delivery for parent alerts (optional)
# Get your key at: https://resend.com/api-keys
# From address must be a verified domain (or use onboarding@resend.dev for testing)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=alerts@yourdomain.com
